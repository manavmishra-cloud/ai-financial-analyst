# Copy this to .env and fill in real values. Never commit .env.

# Optional: only needed if you want the Anthropic Claude API fallback.
ANTHROPIC_API_KEY=

# Optional: point Streamlit at a remote Ollama via SSH tunnel.
# Example workflow to use a GPU machine called `discovery`:
#   1. From this machine, open the tunnel and leave the terminal running:
#        ssh -L 11435:localhost:11434 user@discovery
#   2. Set this variable to the forwarded port:
#        OLLAMA_URL=http://localhost:11435
# When unset, defaults to http://localhost:11434 (this machine's Ollama).
OLLAMA_URL=
